{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "MD Toolkit",
  "version": "1.0.0",
  "identifier": "com.mdtoolkit.app",
  "build": {
    "beforeDevCommand": "npm run build",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../web"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "MD Toolkit",
        "width": 1280,
        "height": 900,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "targets": ["nsis"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "category": "Productivity",
    "shortDescription": "Local Markdown toolkit with Chat",
    "longDescription": "MD Toolkit — local-first Markdown notes, project docs, and chat capture. Based on files.md with optional plugins (docs, kanban).",
    "copyright": "Copyright © MD Toolkit",
    "windows": {
      "webviewInstallMode": {
        "type": "downloadBootstrapper",
        "silent": true
      },
      "nsis": {
        "installMode": "currentUser",
        "installerIcon": "icons/icon.ico",
        "languages": ["English"],
        "displayLanguageSelector": false
      }
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDkyRkFDMTQxRjJEMkREMjgKUldRbzNkTHlRY0g2a3VUUWdXbldKNmY0aFpQY0JVM25XOHdBYlh2Q1FaYVp3SXNSZkozTmxxY2YK",
      "endpoints": [
        "https://github.com/CalebCao9420/files.md/releases/latest/download/latest.json"
      ],
      "windows": {
        "installMode": "passive"
      }
    }
  }
}
